## cli/ttl @implemented

- label: agent-store push --ttl sets expiry time as _expires_at attribute
  command: bash -c "TESTDIR=\$(mktemp -d) && export AGENT_STORE_PATH=\"\$TESTDIR/.agent-store\" && AS=target/release/agent-store && \$AS init >/dev/null 2>&1 && echo data | \$AS push --ttl 1h -q && \$AS query --json | python3 -c 'import sys,json; d=json.load(sys.stdin); assert \"_expires_at\" in d[0][\"attributes\"]; print(\"OK\")' && rm -rf \"\$TESTDIR\""
- label: agent-store gc collects entries past their TTL
  command: bash -c "TESTDIR=\$(mktemp -d) && export AGENT_STORE_PATH=\"\$TESTDIR/.agent-store\" && AS=target/release/agent-store && \$AS init >/dev/null 2>&1 && echo old | \$AS push --ttl 1s -q && echo keep | \$AS push -q && sleep 2 && \$AS gc 2>&1 | grep -q 'Collected 1' && test \"\$(\$AS query --count)\" = '1' && rm -rf \"\$TESTDIR\""
- label: agent-store gc --dry-run shows count without deleting
  command: bash -c "TESTDIR=\$(mktemp -d) && export AGENT_STORE_PATH=\"\$TESTDIR/.agent-store\" && AS=target/release/agent-store && \$AS init >/dev/null 2>&1 && echo old | \$AS push --ttl 1s -q && sleep 2 && \$AS gc --dry-run 2>&1 | grep -q 'would be collected' && test \"\$(\$AS query --count)\" = '1' && rm -rf \"\$TESTDIR\""
- label: agent-store push --ttl rejects invalid duration format

## cli/tag @implemented

- label: agent-store tag adds one or more labels to an existing entry
  command: bash -c "TESTDIR=\$(mktemp -d) && export AGENT_STORE_PATH=\"\$TESTDIR/.agent-store\" && AS=target/release/agent-store && \$AS init >/dev/null 2>&1 && ID=\$(echo test | \$AS push --id-only --strip) && \$AS tag \"\$ID\" done reviewed 2>&1 && LABELS=\$(\$AS pull \"\$ID\" --json | python3 -c \"import sys,json; print(','.join(sorted(json.load(sys.stdin)['labels'])))\") && rm -rf \"\$TESTDIR\" && test \"\$LABELS\" = 'done,reviewed'"
- label: agent-store tag is idempotent when adding a label that already exists
  command: bash -c "TESTDIR=\$(mktemp -d) && export AGENT_STORE_PATH=\"\$TESTDIR/.agent-store\" && AS=target/release/agent-store && \$AS init >/dev/null 2>&1 && ID=\$(echo test | \$AS push --label x --id-only --strip) && \$AS tag \"\$ID\" x 2>&1 && COUNT=\$(\$AS pull \"\$ID\" --json | python3 -c \"import sys,json; print(len(json.load(sys.stdin)['labels']))\") && rm -rf \"\$TESTDIR\" && test \"\$COUNT\" = '1'"
- label: agent-store tag exits 1 with clear message for nonexistent entry ID
  command: bash -c "TESTDIR=\$(mktemp -d) && export AGENT_STORE_PATH=\"\$TESTDIR/.agent-store\" && AS=target/release/agent-store && \$AS init >/dev/null 2>&1 && \$AS tag fake-id oops 2>&1 | grep -q 'entry not found' && rm -rf \"\$TESTDIR\""
- label: agent-store tag rejects empty label with error and exit 1
  command: bash -c "TESTDIR=\$(mktemp -d) && export AGENT_STORE_PATH=\"\$TESTDIR/.agent-store\" && AS=target/release/agent-store && \$AS init >/dev/null 2>&1 && ID=\$(echo test | \$AS push --id-only --strip) && \$AS tag \"\$ID\" '' 2>&1 | grep -q 'label cannot be empty' && rm -rf \"\$TESTDIR\""


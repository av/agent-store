# agent-store facts

## domain

# agent-store is a CLI tool for agents to store and query unstructured data.
# Core entities: store (SQLite database), entry (a data record), label (tag on an entry),
# entity-type (classification of an entry), attribute (key-value pair on an entry).
# A store is per-project (default: .agent-store/store.db in current directory).

## project

- label: project compiles successfully
  command: cargo check
- label: all tests pass
  command: cargo test --quiet
- label: code is formatted
  command: cargo fmt --check

## cli/init @implemented

- label: agent-store init creates a new store in .agent-store/store.db
  command: cd /tmp/as-test-init && rm -rf .agent-store && agent-store init && test -f .agent-store/store.db && echo "OK"
- label: agent-store --help prints usage information
  command: agent-store --help 2>&1 | grep -q "agent-store" && echo "OK"
- label: agent-store init in existing store is idempotent
  command: cd /tmp/as-test-init && agent-store init && agent-store init && echo "OK"

## cli/push @implemented

- label: agent-store push stores data from stdin
  command: cd /tmp/as-test-push && rm -rf .agent-store && agent-store init && echo '{"name":"test"}' | agent-store push && echo "OK"
- label: agent-store push accepts --label flag to tag entry
  command: cd /tmp/as-test-push && echo "hello" | agent-store push --label greeting && agent-store query --label greeting | grep -q "hello" && echo "OK"
- label: agent-store push accepts --type flag to set entity type
  command: cd /tmp/as-test-push && echo "config data" | agent-store push --type config && agent-store query --type config | grep -q "config data" && echo "OK"

## cli/pull @implemented

- label: agent-store pull retrieves entry by ID
  command: cd /tmp/as-test-pull && rm -rf .agent-store && agent-store init && ID=$(echo "payload" | agent-store push 2>&1 | awk '{print $3}') && agent-store pull "$ID" | grep -q "payload" && echo "OK"
- label: agent-store pull outputs entry data to stdout for piping
  command: cd /tmp/as-test-pull && ID=$(echo "pipe-test" | agent-store push 2>&1 | awk '{print $3}') && agent-store pull "$ID" | cat | grep -q "pipe-test" && echo "OK"

## cli/query @implemented

- label: agent-store query lists entries with optional filters
  command: cd /tmp/as-test-query && rm -rf .agent-store && agent-store init && echo "a" | agent-store push --label x && echo "b" | agent-store push --label y && agent-store query --label x | grep -q "a" && echo "OK"
- label: agent-store query --type filters by entity type
  command: cd /tmp/as-test-query && agent-store query --type config 2>&1 | head -1 && echo "OK"
- label: agent-store query with no filters lists all entries
  command: cd /tmp/as-test-query && agent-store query | wc -l | xargs test 0 -lt && echo "OK"

## cli/schema @implemented

- label: agent-store schema shows entity types and label counts
  command: cd /tmp/as-test-schema && rm -rf .agent-store && agent-store init && echo "d1" | agent-store push --type note --label important && agent-store schema | grep -q "note" && echo "OK"

## cli/stats @implemented

- label: agent-store stats shows total entry count and store size
  command: cd /tmp/as-test-stats && rm -rf .agent-store && agent-store init && echo "x" | agent-store push && agent-store stats | grep -qE "[0-9]+ entr" && echo "OK"

## cli/attributes @implemented

- label: agent-store push accepts --attr key=value pairs
  command: cd /tmp/as-test-attr && rm -rf .agent-store && agent-store init && echo "item" | agent-store push --attr priority=high --attr status=open && agent-store query --attr priority=high | grep -q "item" && echo "OK"

## cli/pipeline @implemented

- label: agent-store query output is newline-delimited for piping
  command: cd /tmp/as-test-pipe && rm -rf .agent-store && agent-store init && echo "line1" | agent-store push && echo "line2" | agent-store push && agent-store query | wc -l | xargs test 1 -lt && echo "OK"
- label: agent-store supports JSON output with --json flag
  command: cd /tmp/as-test-pipe && agent-store query --json | python3 -c "import sys,json; json.load(sys.stdin)" && echo "OK"

## cli/skills @implemented

- label: agent-store skills lists available skills with descriptions
  command: agent-store skills list 2>&1 | grep -q "agent-store" && echo "OK"
- label: agent-store skills get agent-store prints the core usage guide
  command: agent-store skills get agent-store 2>&1 | grep -q "agent-store" && echo "OK"
- label: agent-store skills get agent-store --full includes references
  command: LINES=$(agent-store skills get agent-store --full 2>&1 | wc -l); SHORT=$(agent-store skills get agent-store 2>&1 | wc -l); test "$LINES" -gt "$SHORT" && echo "OK"
- label: agent-store skills path agent-store prints the skill data path
  command: agent-store skills path agent-store 2>&1 | grep -q "agent-store" && echo "OK"

## cli/config @implemented

- label: agent-store uses .agent-store/ in current directory by default
  command: cd /tmp/as-test-config && rm -rf .agent-store && agent-store init && test -d .agent-store && echo "OK"
- label: AGENT_STORE_PATH env var overrides default store location
  command: rm -rf /tmp/as-custom-store && AGENT_STORE_PATH=/tmp/as-custom-store agent-store init && test -f /tmp/as-custom-store/store.db && echo "OK"
- label: store resolves to project root .agent-store/ regardless of CWD within the repo
  command: rm -rf /tmp/as-h2-test && mkdir -p /tmp/as-h2-test/.git /tmp/as-h2-test/sub/deep && cd /tmp/as-h2-test && agent-store init && echo "rootdata" | agent-store push --quiet && cd /tmp/as-h2-test/sub/deep && echo "subdata" | agent-store push --label fromdeep --quiet && agent-store query --label fromdeep | grep -q "subdata" && echo "OK"
  tags: [spec, implemented]

# cli

## init
- label: agent-store init installs skills to .agents/skills/
  command: cd /tmp/as-test-skills && rm -rf .agent-store .agents .claude AGENTS.md && mkdir -p .git && agent-store init && test -f .agents/skills/agent-store/SKILL.md && echo "OK"
  tags: [spec, implemented]
- label: agent-store init adds agent docs section to AGENTS.md
  command: cd /tmp/as-test-skills && cat AGENTS.md | grep -q "agent-store:start" && echo "OK"
  tags: [spec, implemented]
- label: agent-store init is idempotent for skills and agent docs
  command: cd /tmp/as-test-skills && agent-store init && agent-store init && test -f .agents/skills/agent-store/SKILL.md && echo "OK"
  tags: [spec, implemented]
- label: agent-store init prints error and skips file when agent docs section has start marker without end marker
  command: cd /tmp/as-test-malformed && rm -rf .agent-store .agents AGENTS.md && mkdir -p .git && agent-store init && printf "<!-- agent-store:start -->\nold content\n" > AGENTS.md && agent-store init 2>&1 | grep -q "missing end marker" && echo "OK"
  tags: [spec, implemented]
- label: agent-store init adds .agent-store/ to .gitignore in git repos so the SQLite database is not accidentally committed
  command: cd /tmp/as-test-gitignore && rm -rf .agent-store .agents .gitignore .git AGENTS.md && mkdir -p .git && agent-store init && grep -q ".agent-store/" .gitignore && echo "OK"
  tags: [spec, implemented]
- label: agent-store init prints a hint directing users to skills after successful completion
  command: rm -rf /tmp/as-hint-test2 && mkdir -p /tmp/as-hint-test2/.git && cd /tmp/as-hint-test2 && /home/everlier/code/agent-store/target/release/agent-store init 2>&1 | grep -q "hint.*skills get agent-store" && echo "OK"
  tags: [spec, implemented]

## help
- label: agent-store --help shows Start here section directing agents to skills
  command: agent-store --help 2>&1 | grep -q "Start here" && echo "OK"
  tags: [spec, implemented]
- label: long help explains that entry payloads cannot be modified after push
  command: agent-store help 2>&1 | grep -q "cannot be modified" && echo "OK"
  tags: [spec, implemented]

## skills
- label: agent-store skills get agent-store-patterns prints workflow recipes
  command: agent-store skills get agent-store-patterns 2>&1 | grep -q "scratchpad" && echo "OK"
  tags: [spec, implemented]
- label: agent-store skills get agent-store-pipelines prints shell composition guide
  command: agent-store skills get agent-store-pipelines 2>&1 | grep -q "Batch import" && echo "OK"
  tags: [spec, implemented]
- label: `skills path <name>` returns `.agents/skills/<name>` — the actual installed location
  command: target/release/agent-store skills path agent-store | grep -qx ".agents/skills/agent-store"
  tags: [spec, implemented]

## resilience
- label: Piping output to head or other short-consuming commands exits cleanly without panicking on broken pipe
  command: agent-store stats 2>/tmp/sigpipe-stderr | head -1 && [ ! -s /tmp/sigpipe-stderr ]
  tags: [spec, implemented]

## stats
- label: stats uses correct singular/plural for entity type and label counts
  command: dir=/tmp/test-m6-$$ && mkdir -p "$dir" && cd "$dir" && git init -q && AGENT_STORE_PATH=.agent-store /home/everlier/code/agent-store/target/release/agent-store init 2>/dev/null 1>/dev/null && echo "d" | AGENT_STORE_PATH=.agent-store /home/everlier/code/agent-store/target/release/agent-store push --type t --label l --quiet 2>/dev/null 1>/dev/null && stats=$(AGENT_STORE_PATH=.agent-store /home/everlier/code/agent-store/target/release/agent-store stats 2>&1) && cd / && rm -rf "$dir" && echo "$stats" | grep -q "1 entity type" && echo "$stats" | grep -q "1 label$" && echo "PASS"
  tags: [spec, implemented]
- label: stats --json outputs a JSON object with entries count, entity_types list, labels list, and their counts
  command: cd /tmp/as-test-stats-json && rm -rf .agent-store && mkdir -p .git && agent-store init > /dev/null && echo "d1" | agent-store push --type note --label todo --quiet > /dev/null && echo "d2" | agent-store push --type task --label done --quiet > /dev/null && agent-store stats --json | jq -e ".entries == 2 and (.entity_types | length) == 2 and (.labels | length) == 2" > /dev/null && echo "OK"
  tags: [spec, implemented]
- label: stats --json includes entries_by_type mapping each entity type to its entry count
  command: cd /tmp/as-test-stats-breakdown && rm -rf .agent-store && agent-store init 2>/dev/null && echo "a" | agent-store push --type note -q && echo "b" | agent-store push --type note -q && echo "c" | agent-store push --type task -q && agent-store stats --json | python3 -c "import sys,json; d=json.load(sys.stdin); assert d[\"entries_by_type\"][\"note\"]==2; assert d[\"entries_by_type\"][\"task\"]==1; print(\"OK\")"
  tags: [spec, implemented]
- label: stats --json includes entries_by_label mapping each label to its entry count
  command: mkdir -p /tmp/as-test-stats-lbl && cd /tmp/as-test-stats-lbl && rm -rf .agent-store && git init -q 2>/dev/null; agent-store init 2>/dev/null && echo "a" | agent-store push --label todo -q && echo "b" | agent-store push --label todo -q && echo "c" | agent-store push --label done -q && agent-store stats --json | python3 -c "import sys,json; d=json.load(sys.stdin); assert d[\"entries_by_label\"][\"todo\"]==2; assert d[\"entries_by_label\"][\"done\"]==1; print(\"OK\")"
  tags: [spec, implemented]
- label: stats human-readable output shows per-type breakdown with counts indented under the type count line
  command: mkdir -p /tmp/as-test-stats-bd2 && cd /tmp/as-test-stats-bd2 && rm -rf .agent-store && git init -q 2>/dev/null; agent-store init 2>/dev/null && echo "a" | agent-store push --type note -q && echo "b" | agent-store push --type note -q && echo "c" | agent-store push --type task -q && agent-store stats 2>&1 | grep -q "note: 2" && agent-store stats 2>&1 | grep -q "task: 1" && echo "OK"
  tags: [spec, implemented]
- label: stats human-readable output shows per-label breakdown with counts indented under the label count line
  command: mkdir -p /tmp/as-test-stats-bd3 && cd /tmp/as-test-stats-bd3 && rm -rf .agent-store && git init -q 2>/dev/null; agent-store init 2>/dev/null && echo "a" | agent-store push --label todo -q && echo "b" | agent-store push --label todo -q && echo "c" | agent-store push --label done -q && agent-store stats 2>&1 | grep -q "todo: 2" && agent-store stats 2>&1 | grep -q "done: 1" && echo "OK"
  tags: [spec, implemented]

## query
- label: query --label accepts multiple values with AND semantics, matching push repeatable --label
  command: cd /tmp/as-test-m3 && rm -rf .agent-store && agent-store init > /dev/null && echo "ab" | agent-store push --label a --label b --quiet > /dev/null && echo "a-only" | agent-store push --label a --quiet > /dev/null && echo "b-only" | agent-store push --label b --quiet > /dev/null && result=$(agent-store query --label a --label b) && [ "$result" = "ab" ]
  tags: [spec, implemented]
- label: query --attr rejects empty key with "attribute key cannot be empty" error and exit 1, matching push validation
  command: cd /tmp/as-test-m3 && /home/everlier/code/agent-store/target/release/agent-store query --attr "=" 2>&1 | grep -q "attribute key cannot be empty" && echo "OK"
  tags: [spec, implemented]
- label: query --count outputs the number of matching entries instead of entry data
  command: echo "count-test-data" | agent-store push --label count-test-xx --quiet > /dev/null && count=$(agent-store query --label count-test-xx --count) && test "$count" -ge 1 && echo "PASS: count=$count"
  tags: [spec, implemented]
- label: query --limit N returns at most N entries
  command: echo "limit-test" | agent-store push --label limit-test-xx --quiet > /dev/null && echo "limit-test-2" | agent-store push --label limit-test-xx --quiet > /dev/null && result=$(agent-store query --label limit-test-xx --json --limit 1 | jq length) && test "$result" -eq 1 && echo "PASS: limit=1 returned 1 entry"
  tags: [spec, implemented]
- label: query --offset N skips the first N entries (requires --limit)
  command: echo "offset-test-1" | agent-store push --label offset-test-xx --quiet > /dev/null && echo "offset-test-2" | agent-store push --label offset-test-xx --quiet > /dev/null && all=$(agent-store query --label offset-test-xx --json | jq length) && offset_result=$(agent-store query --label offset-test-xx --json --limit 100 --offset 1 | jq length) && test "$offset_result" -lt "$all" && echo "PASS: offset skipped entries"
  tags: [spec, implemented]
- label: query --latest returns only the single most recent matching entry (LIMIT 1)
  command: echo "latest-test-a" | agent-store push --label latest-test-fact && echo "latest-test-b" | agent-store push --label latest-test-fact && count=$(agent-store query --label latest-test-fact --latest --json | jq length) && test "$count" -eq 1
  tags: [spec, implemented]
- label: query --latest conflicts with --limit (mutually exclusive via clap)
  command: agent-store query --latest --limit 5 2>&1; test $? -ne 0
  tags: [spec, implemented]
- label: query --reverse/-r reverses sort order to oldest-first (ORDER BY created_at ASC)
  command: echo "rev-old" | agent-store push --label reverse-test-fact && sleep 1 && echo "rev-new" | agent-store push --label reverse-test-fact && first=$(agent-store query --label reverse-test-fact --reverse --json | jq -r ".[0].data") && test "$first" = "rev-old"
  tags: [spec, implemented]
- label: query --data filters entries by substring match in entry data
  command: export AGENT_STORE_PATH=$(mktemp -d) && agent-store init >/dev/null 2>&1 && echo "hello error world" | agent-store push --label logs --quiet && echo "all good" | agent-store push --label logs --quiet && test "$(agent-store query --data error --count)" = "1"
  tags: [spec, implemented]
- label: query --data works with all existing filters including --label, --json, --count, --latest, --reverse, --limit, --offset
  command: export AGENT_STORE_PATH=$(mktemp -d) && agent-store init >/dev/null 2>&1 && echo "error in logs" | agent-store push --label logs --quiet && echo "error in notes" | agent-store push --label notes --quiet && test "$(agent-store query --data error --label logs --count)" = "1"
  tags: [spec, implemented]
- label: query --not-label excludes entries with the given label; repeatable with AND semantics (all specified labels excluded)
  command: cd /tmp && rm -rf as-test-8kb && mkdir as-test-8kb && cd as-test-8kb && git init -q && agent-store init 2>/dev/null && echo "a" | agent-store push --label todo -q && echo "b" | agent-store push --label todo --label done -q && echo "c" | agent-store push --label todo --label archived -q && test "$(agent-store query --label todo --not-label done --count)" = "2" && test "$(agent-store query --not-label done --not-label archived --count)" = "1" && rm -rf /tmp/as-test-8kb
  tags: [spec, implemented]
- label: query --count respects --limit and --offset by wrapping in a subquery so count reflects the paginated result set
  command: cd /tmp/agent-store-test-countlim && rm -rf .agent-store && agent-store init >/dev/null 2>&1 && for i in 1 2 3 4 5; do echo "entry$i" | agent-store push --label counttest -q; done && RESULT=$(agent-store query --label counttest --count --limit 3) && test "$RESULT" = "3"
  tags: [spec, implemented]
- label: query --after filters entries to only those created after the given ISO 8601 timestamp
  command: cd /tmp/agent-store-test-after && rm -rf .agent-store && agent-store init >/dev/null 2>&1 && echo "old" | agent-store push --label timetest -q && sleep 1 && MIDPOINT=$(date -u +"%Y-%m-%d %H:%M:%S") && sleep 1 && echo "new" | agent-store push --label timetest -q && RESULT=$(agent-store query --label timetest --after "$MIDPOINT" --count) && test "$RESULT" = "1"
  tags: [spec, implemented]
- label: query --before filters entries to only those created before the given ISO 8601 timestamp
  command: cd /tmp/agent-store-test-before && rm -rf .agent-store && agent-store init >/dev/null 2>&1 && echo "old" | agent-store push --label timetest -q && sleep 1 && MIDPOINT=$(date -u +"%Y-%m-%d %H:%M:%S") && sleep 1 && echo "new" | agent-store push --label timetest -q && RESULT=$(agent-store query --label timetest --before "$MIDPOINT" --count) && test "$RESULT" = "1"
  tags: [spec, implemented]
- label: query --not-type excludes entries with given entity type; repeatable and NULL-safe so entries with no type are not excluded
  command: agent-store init 2>/dev/null; echo "a" | agent-store push --type note --label test-nt; echo "b" | agent-store push --type log --label test-nt; echo "c" | agent-store push --label test-nt; RESULT=$(agent-store query --label test-nt --not-type note --json 2>/dev/null | jq -r ".[].data" | sort); [ "$RESULT" = "$(printf "b\nc")" ] && echo "PASS" || echo "FAIL: got $RESULT"
  tags: [spec, implemented]
- label: query --not-attr key=value excludes entries having the specified attribute; repeatable with AND semantics
  command: agent-store init 2>/dev/null; echo "keep" | agent-store push --attr status=active --label test-na; echo "drop" | agent-store push --attr status=archived --label test-na; RESULT=$(agent-store query --label test-na --not-attr status=archived --json 2>/dev/null | jq -r ".[].data"); [ "$RESULT" = "keep" ] && echo "PASS" || echo "FAIL: got $RESULT"
  tags: [spec, implemented]

## push
- label: push -q/--quiet suppresses all output including the entry ID
  command: cd /tmp/as-test-push-quiet && rm -rf .agent-store && mkdir -p .git && agent-store init > /dev/null && output=$(echo "quiet-test" | agent-store push --label qt -q 2>&1) && test -z "$output" && echo "OK"
  tags: [spec, implemented]
- label: push --id-only outputs only the raw UUID with no prefix text for scripting
  command: echo test | agent-store push --label idonly-test --id-only 2>&1 | grep -qE "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$" && echo PASS || echo FAIL
  tags: [spec, implemented]
- label: push --id-only conflicts with --quiet (mutually exclusive via clap)
  command: echo test | agent-store push --label idonly-conflict --id-only --quiet 2>&1 | grep -qi "cannot be used with\|conflict" && echo PASS || echo FAIL
  tags: [spec, implemented]
- label: push --timestamp overrides created_at with the specified ISO 8601 timestamp instead of using current time
  command: cd /tmp/as-test-timestamp && rm -rf .agent-store && agent-store init 2>/dev/null && ID=$(echo "old entry" | agent-store push --label test --timestamp "2024-01-15 10:30:00" --id-only) && agent-store pull "$ID" --json | python3 -c "import sys,json; d=json.load(sys.stdin); assert d[\"created_at\"]==\"2024-01-15 10:30:00\"; print(\"OK\")"
  tags: [spec, implemented]
- label: push without --timestamp uses current time as created_at (default behavior preserved)
  command: cd /tmp/as-test-timestamp && ID=$(echo "recent" | agent-store push --label test --id-only) && agent-store pull "$ID" --json | python3 -c "import sys,json; d=json.load(sys.stdin); assert d[\"created_at\"].startswith(\"20\"); print(\"OK\")"
  tags: [spec, implemented]
- label: push --strip trims trailing whitespace from stdin data before storing
  command: DIR=$(mktemp -d) && cd "$DIR" && agent-store init >/dev/null 2>&1 && ID=$(echo "hello" | agent-store push --label test --strip --id-only) && DATA=$(agent-store pull "$ID" --raw) && test "$DATA" = "hello" && rm -rf "$DIR"
  tags: [spec, implemented]
- label: push --strip works with --file flag to trim trailing whitespace from file data
  command: DIR=$(mktemp -d) && cd "$DIR" && agent-store init >/dev/null 2>&1 && printf "file content\n\n" > testfile.txt && ID=$(agent-store push --file testfile.txt --strip --id-only) && DATA=$(agent-store pull "$ID" --raw) && test "$DATA" = "file content" && rm -rf "$DIR"
  tags: [spec, implemented]

## completions
- label: agent-store completions <shell> generates shell completion scripts for the specified shell and writes to stdout
  command: agent-store completions bash 2>&1 | head -3 | grep -q "complete\|_agent" && echo PASS || echo FAIL
  tags: [spec, implemented]

## export
- label: agent-store export outputs all entries as JSONL (one JSON object per line) to stdout for backup and migration
  command: agent-store export | head -1 | jq -e ".id" > /dev/null 2>&1 && echo PASS || echo FAIL
  tags: [spec, implemented]
- label: agent-store export --label X exports only entries matching the specified label filter
  command: echo "test-export-filter" | agent-store push --label unique-export-test-label -q && COUNT=$(agent-store export --label unique-export-test-label | wc -l) && test "$COUNT" -ge 1 && echo PASS || echo FAIL
  tags: [spec, implemented]
- label: export --not-label excludes entries with specified labels, matching query filter parity
  command: agent-store export --not-label nonexistent 2>&1 | head -1 | grep -qE "^\{" && echo PASS || echo FAIL
  tags: [spec, implemented]
- label: export --data filters entries by substring match in data, matching query filter parity
  command: agent-store export --data test 2>&1 | head -1 | grep -qE "^\{" && echo PASS || echo FAIL
  tags: [spec, implemented]
- label: export --after and --before filter entries by date range, matching query filter parity
  command: agent-store export --after "2020-01-01" --before "2099-01-01" 2>&1 | head -1 | grep -qE "^\{" && echo PASS || echo FAIL
  tags: [spec, implemented]
- label: export --id filters to a single entry by UUID, matching query --id filter parity
  command: TEST_ID=$(echo "export-id-test" | agent-store push --id-only --label export-id-test) && agent-store export --id "$TEST_ID" | jq -r .id | grep -q "$TEST_ID"
  tags: [spec, implemented]
- label: export --not-type and --not-attr exclusion filters match query filter parity
  command: agent-store init 2>/dev/null; echo "a" | agent-store push --type note --label test-ent; echo "b" | agent-store push --type log --label test-ent; RESULT=$(agent-store export --label test-ent --not-type note 2>/dev/null | jq -r ".data"); [ "$RESULT" = "b" ] && echo "PASS" || echo "FAIL: got $RESULT"
  tags: [spec, implemented]

## import
- label: agent-store import reads JSONL from stdin and inserts entries into the store, printing a summary of imported entries and errors
  command: echo "test data" | agent-store push --label import-test && agent-store export --label import-test | agent-store import 2>&1 | grep -q "Imported"
  tags: [spec, implemented]
- label: agent-store import reports parse errors with line numbers and continues processing remaining lines
  command: echo "{\"invalid" | agent-store import 2>&1 | grep -qE "line 1.*error|1 error"
  tags: [spec, implemented]
- label: agent-store export | agent-store import round-trips entries — exported entries can be re-imported as new entries with fresh IDs
  command: echo "test-roundtrip" | agent-store push --label rt-test && BEFORE=$(agent-store query --label rt-test --count) && agent-store export --label rt-test | agent-store import && AFTER=$(agent-store query --label rt-test --count) && [ "$AFTER" -gt "$BEFORE" ]
  tags: [spec, implemented]
- label: import --dry-run parses and validates JSONL without inserting, prints summary with count of entries that would be imported and errors
  command: echo "{\"data\":\"test\"}" | agent-store import --dry-run 2>&1 | grep -q "Dry run" && echo PASS || echo FAIL
  tags: [spec, implemented]
- label: import preserves created_at timestamps from JSONL when present, using current time as fallback when missing
  command: cd /tmp/test-import-ts && rm -rf .agent-store && agent-store init > /dev/null 2>&1 && echo "original" | agent-store push --label test --timestamp "2020-06-15 12:00:00" -q && agent-store export > /tmp/test-import-ts-backup.jsonl && rm -rf .agent-store && agent-store init > /dev/null 2>&1 && agent-store import < /tmp/test-import-ts-backup.jsonl 2>&1 && agent-store query --json --latest | jq -r .created_at | grep -q "2020-06-15 12:00:00" && echo PASS || echo FAIL
  tags: [spec, implemented]

## purge
- label: agent-store purge without --confirm prints warning message and exits 1
  command: agent-store purge 2>&1; test $? -eq 1
  tags: [spec, implemented]
- label: agent-store purge --confirm deletes all entries and prints count of purged entries
  command: export AGENT_STORE_PATH=$(mktemp -d) && agent-store init >/dev/null 2>&1 && echo "test1" | agent-store push --label x --quiet && echo "test2" | agent-store push --label y --quiet && agent-store purge --confirm 2>&1 | grep -q "Purged 2 entries"
  tags: [spec, implemented]

## pull
- label: pull --json outputs full entry as JSON object matching query --json format (id, entity_type, labels, data, created_at, attributes)
  command: cd /tmp && rm -rf as-test-r1q && mkdir as-test-r1q && cd as-test-r1q && git init -q && agent-store init 2>/dev/null && ID=$(echo "test data" | agent-store push --label tag1 --type note --attr k=v --id-only) && OUT=$(agent-store pull "$ID" --json) && echo "$OUT" | jq -e ".id and .data and .labels and .created_at and .attributes and (.entity_type == \"note\")" > /dev/null && rm -rf /tmp/as-test-r1q
  tags: [spec, implemented]
- label: pull --raw omits trailing newline for binary-safe piping
  command: TEST_ID=$(echo -n "rawtest" | agent-store push --id-only --label raw-test) && BYTES=$(agent-store pull "$TEST_ID" --raw | wc -c) && test "$BYTES" = "7"
  tags: [spec, implemented]

## attrs
- label: agent-store attrs lists all unique attribute keys in the store, one per line, sorted alphabetically
  command: DIR=$(mktemp -d) && cd "$DIR" && agent-store init >/dev/null 2>&1 && echo "d1" | agent-store push --attr color=red --attr size=large -q && echo "d2" | agent-store push --attr color=blue --attr weight=10 -q && OUTPUT=$(agent-store attrs) && echo "$OUTPUT" | head -1 | grep -q "^color$" && test "$(echo "$OUTPUT" | wc -l)" = "3" && rm -rf "$DIR"
  tags: [spec, implemented]
- label: agent-store attrs --json outputs a JSON array of unique attribute keys
  command: DIR=$(mktemp -d) && cd "$DIR" && agent-store init >/dev/null 2>&1 && echo "d1" | agent-store push --attr color=red --attr size=large -q && agent-store attrs --json | python3 -c "import json,sys; d=json.load(sys.stdin); assert d==[\"color\",\"size\"]" && rm -rf "$DIR"
  tags: [spec, implemented]
- label: agent-store attrs --count shows entry count next to each attribute key
  command: DIR=$(mktemp -d) && cd "$DIR" && agent-store init >/dev/null 2>&1 && echo "d1" | agent-store push --attr color=red -q && echo "d2" | agent-store push --attr color=blue -q && echo "d3" | agent-store push --attr size=large -q && agent-store attrs --count | head -1 | grep -q "^color (2)$" && rm -rf "$DIR"
  tags: [spec, implemented]

## cli/delete @implemented

- label: agent-store delete <id> deletes a single entry by ID with its labels and attributes, no --confirm needed
  command: bash -c "TESTDIR=\$(mktemp -d) && export AGENT_STORE_PATH=\"\$TESTDIR/.agent-store\" && AS=target/release/agent-store && \$AS init >/dev/null 2>&1 && ID=\$(echo test | \$AS push --label x --attr k=v --id-only --strip) && \$AS delete \"\$ID\" 2>&1 | grep -q 'Deleted' && test \"\$(\$AS query --count)\" = '0' && test \"\$(\$AS labels)\" = '' && rm -rf \"\$TESTDIR\""
- label: agent-store delete with filters requires --confirm flag; without it prints count and exits 1
  command: bash -c "TESTDIR=\$(mktemp -d) && export AGENT_STORE_PATH=\"\$TESTDIR/.agent-store\" && AS=target/release/agent-store && \$AS init >/dev/null 2>&1 && echo a | \$AS push --label todo -q && echo b | \$AS push --label todo -q && \$AS delete --label todo 2>&1 | grep -q 'Would delete 2' && test \$? -eq 0 && rm -rf \"\$TESTDIR\""
- label: agent-store delete with filters and --confirm deletes matching entries
  command: bash -c "TESTDIR=\$(mktemp -d) && export AGENT_STORE_PATH=\"\$TESTDIR/.agent-store\" && AS=target/release/agent-store && \$AS init >/dev/null 2>&1 && echo a | \$AS push --label todo -q && echo b | \$AS push --label done -q && \$AS delete --label todo --confirm 2>&1 | grep -q 'Deleted 1' && test \"\$(\$AS query --count)\" = '1' && rm -rf \"\$TESTDIR\""
- label: agent-store delete with no ID and no filters prints error and exits 1
  command: bash -c "TESTDIR=\$(mktemp -d) && export AGENT_STORE_PATH=\"\$TESTDIR/.agent-store\" && AS=target/release/agent-store && \$AS init >/dev/null 2>&1 && \$AS delete 2>&1 | grep -q 'specify an ID or at least one filter' && rm -rf \"\$TESTDIR\""
- label: agent-store delete exits 1 with error for nonexistent entry ID
  command: bash -c "TESTDIR=\$(mktemp -d) && export AGENT_STORE_PATH=\"\$TESTDIR/.agent-store\" && AS=target/release/agent-store && \$AS init >/dev/null 2>&1 && \$AS delete fake-id 2>&1 | grep -q 'entry not found' && rm -rf \"\$TESTDIR\""


- label: alias set saves a named query and alias run executes it
  command: bash -c "TESTDIR=\$(mktemp -d) && export AGENT_STORE_PATH=\"\$TESTDIR/.agent-store\" && AS=/home/everlier/code/agent-store/target/debug/agent-store && \$AS init >/dev/null 2>&1 && echo urgent-data | \$AS push --label urgent --type task -q && \$AS alias set myq -- --label urgent --type task && RESULT=\$(\$AS alias run myq) && rm -rf \"\$TESTDIR\" && test \"\$RESULT\" = 'urgent-data'"
- label: alias list shows saved aliases with name and args
  command: bash -c "TESTDIR=\$(mktemp -d) && export AGENT_STORE_PATH=\"\$TESTDIR/.agent-store\" && AS=/home/everlier/code/agent-store/target/debug/agent-store && \$AS init >/dev/null 2>&1 && \$AS alias set myq -- --label urgent && \$AS alias list | grep -q 'myq' && rm -rf \"\$TESTDIR\""
- label: alias rm removes an alias and exits 1 if alias not found

## cli/prefix-id @spec

- label: pull with an unambiguous ID prefix resolves to the full entry
  command: bash -c "TESTDIR=\$(mktemp -d) && export AGENT_STORE_PATH=\"\$TESTDIR/.agent-store\" && AS=target/release/agent-store && \$AS init >/dev/null 2>&1 && ID=\$(echo test-prefix | \$AS push --id-only --strip) && PREFIX=\"\${ID:0:7}\" && RESULT=\$(\$AS pull \"\$PREFIX\") && rm -rf \"\$TESTDIR\" && test \"\$RESULT\" = 'test-prefix'"
  tags: [implemented]
- label: ambiguous ID prefix prints error with match count and exits 1
  command: bash -c "TESTDIR=\$(mktemp -d) && export AGENT_STORE_PATH=\"\$TESTDIR/.agent-store\" && AS=target/release/agent-store && \$AS init >/dev/null 2>&1 && for i in \$(seq 1 30); do echo d\$i | \$AS push -q; done && CHAR=\$(\$AS query --json | python3 -c \"import sys,json,collections; ids=[e['id'] for e in json.load(sys.stdin)]; c=collections.Counter(i[0] for i in ids); print(c.most_common(1)[0][0])\") && \$AS pull \"\$CHAR\" 2>&1 | grep -q 'ambiguous ID prefix' && rm -rf \"\$TESTDIR\""
  tags: [implemented]
- label: non-existent ID prefix prints not-found error and exits 1
  command: bash -c "TESTDIR=\$(mktemp -d) && export AGENT_STORE_PATH=\"\$TESTDIR/.agent-store\" && AS=target/release/agent-store && \$AS init >/dev/null 2>&1 && echo d | \$AS push -q && \$AS pull zzzzzzz 2>&1 | grep -q 'entry not found' && rm -rf \"\$TESTDIR\""
  tags: [implemented]

## cli/query-shortcuts @spec

- label: query --first returns the single oldest matching entry
  command: bash -c "TESTDIR=\$(mktemp -d) && export AGENT_STORE_PATH=\"\$TESTDIR/.agent-store\" && AS=target/release/agent-store && \$AS init >/dev/null 2>&1 && echo oldest | \$AS push --label qs-test --strip --timestamp '2024-01-01 10:00:00' -q && echo newest | \$AS push --label qs-test --strip --timestamp '2024-01-02 10:00:00' -q && RESULT=\$(\$AS query --label qs-test --first) && rm -rf \"\$TESTDIR\" && test \"\$RESULT\" = 'oldest'"
- label: query --last returns the single newest matching entry
  command: bash -c "TESTDIR=\$(mktemp -d) && export AGENT_STORE_PATH=\"\$TESTDIR/.agent-store\" && AS=target/release/agent-store && \$AS init >/dev/null 2>&1 && echo oldest | \$AS push --label qs-test2 --strip --timestamp '2024-01-01 10:00:00' -q && echo newest | \$AS push --label qs-test2 --strip --timestamp '2024-01-02 10:00:00' -q && RESULT=\$(\$AS query --label qs-test2 --last) && rm -rf \"\$TESTDIR\" && test \"\$RESULT\" = 'newest'"
- label: query --first and --last conflict with --limit and each other
  command: bash -c "TESTDIR=\$(mktemp -d) && export AGENT_STORE_PATH=\"\$TESTDIR/.agent-store\" && AS=target/release/agent-store && \$AS init >/dev/null 2>&1 && echo d | \$AS push -q && \$AS query --first --last 2>&1 | grep -qi 'cannot be used' && \$AS query --first --limit 5 2>&1 | grep -qi 'cannot be used' && \$AS query --last --limit 5 2>&1 | grep -qi 'cannot be used' && rm -rf \"\$TESTDIR\""


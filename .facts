- label: alias run supports --mode for export and delete
  command: bash -c "TESTDIR=\$(mktemp -d) && export AGENT_STORE_PATH=\"\$TESTDIR/.agent-store\" && AS=/home/everlier/code/agent-store/target/debug/agent-store && \$AS init >/dev/null 2>&1 && echo data | \$AS push --label x -q && \$AS alias set myq -- --label x && \$AS alias run myq --mode export | jq -e '.data' >/dev/null && rm -rf \"\$TESTDIR\""
